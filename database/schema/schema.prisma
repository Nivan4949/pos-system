datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      String    @default("CASHIER") // ADMIN, MANAGER, CASHIER
  license   License?  @relation(fields: [licenseId], references: [id])
  licenseId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  devices   Device[]
}

model License {
  id          String   @id @default(uuid())
  key         String   @unique
  maxDevices  Int      @default(1)
  expiryDate  DateTime
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED, BLOCKED
  users       User[]
  devices     Device[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Device {
  id           String   @id @default(uuid())
  deviceId     String   @unique // Hardware fingerpint / Browser ID
  name         String?
  authorized   Boolean  @default(false)
  lastLogin    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?
  license      License? @relation(fields: [licenseId], references: [id])
  licenseId    String?
  createdAt    DateTime @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
}

model Product {
  id             String         @id @default(uuid())
  name           String
  barcode        String?        @unique
  category       Category?      @relation(fields: [categoryId], references: [id])
  categoryId     String?
  brand          String?
  purchasePrice  Float
  sellingPrice   Float
  gstRate        Float          @default(18)
  stockQuantity  Int            @default(0)
  unit           String         @default("pcs")
  supplier       String?
  image          String?
  is_active      Boolean        @default(true)
  orderItems     OrderItem[]
  inventoryLogs  InventoryLog[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Customer {
  id            String   @id @default(uuid())
  name          String
  phone         String?  @unique
  email         String?
  loyaltyPoints Int      @default(0)
  creditBalance Float    @default(0)
  orders        Order[]
  is_active     Boolean  @default(true)
  isSynced      Boolean  @default(false)
  serverId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id           String      @id @default(uuid())
  invoiceNo    String      @unique
  customer     Customer?   @relation(fields: [customerId], references: [id])
  customerId   String?
  subtotal     Float
  discount     Float       @default(0)
  taxTotal     Float
  grandTotal   Float
  paymentMode  String      
  status       String      @default("COMPLETED")
  orderItems   OrderItem[]
  payments     Payment[]
  isSynced     Boolean     @default(false)
  serverId     String?     @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id         String  @id @default(uuid())
  order      Order   @relation(fields: [orderId], references: [id])
  orderId    String
  product    Product @relation(fields: [productId], references: [id])
  productId  String
  quantity   Int
  price      Float
  discount   Float   @default(0)
  taxAmount  Float
  total      Float
}

model InventoryLog {
  id         String   @id @default(uuid())
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  type       String   
  quantity   Int
  reason     String?
  createdAt  DateTime @default(now())
}

model Payment {
  id            String   @id @default(uuid())
  order         Order    @relation(fields: [orderId], references: [id])
  orderId       String
  method        String   
  amount        Float
  transactionId String?
  status        String   @default("SUCCESS")
  createdAt     DateTime @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}